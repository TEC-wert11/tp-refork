<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="WeeklyHistoryController">
    <children>
        <VBox spacing="20.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <children>
                <Label fx:id="titleLabel" style="-fx-font-size: 24;" />
                <Label fx:id="periodLabel" style="-fx-font-size: 16;" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="contentContainer" spacing="15.0" style="-fx-padding: 10;" />
                    </content>
                </ScrollPane>
                <Button text="Back" onAction="#handleBack" prefWidth="120.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
