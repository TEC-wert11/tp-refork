<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="xmoke.controller.TodayHistoryController">
    <children>
        <VBox spacing="18.0" AnchorPane.topAnchor="24.0" AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0" AnchorPane.bottomAnchor="24.0">
            <children>
                <Label text="Today's Completion History" styleClass="page-heading" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="usersContainer" spacing="16.0" />
                    </content>
                </ScrollPane>
                <Button text="Back" onAction="#handleBack" styleClass="ghost" prefWidth="120.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
