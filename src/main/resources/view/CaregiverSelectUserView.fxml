<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="xmoke.controller.CaregiverSelectUserController">
    <children>
        <VBox alignment="CENTER" spacing="18.0" AnchorPane.topAnchor="40.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="40.0">
            <children>
                <Label fx:id="titleLabel" styleClass="dialog-title" />
                <VBox fx:id="userContainer" alignment="CENTER" spacing="12.0" />
                <Button text="Back" onAction="#handleBack" styleClass="ghost" prefWidth="220.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
