<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="xmoke.controller.LoginController">
    <children>
        <VBox alignment="CENTER" spacing="22.0" AnchorPane.topAnchor="40.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="40.0">
            <children>
                <Label text="Healthcare Everyday" styleClass="app-title" />
                <Label text="Who are you?" styleClass="app-subtitle" />
                <VBox fx:id="userContainer" alignment="CENTER" spacing="12.0" />
                <Button text="Caregiver" onAction="#handleCaregiver" styleClass="secondary" prefWidth="260.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
