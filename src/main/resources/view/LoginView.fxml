<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="LoginController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.topAnchor="40.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="40.0">
            <children>
                <Text text="Healthcare Everyday" style="-fx-font-size: 28;" />
                <Text text="Who are you?" style="-fx-font-size: 18;" />
                <VBox fx:id="userContainer" alignment="CENTER" spacing="10.0" />
                <Button text="Caregiver" onAction="#handleCaregiver" prefWidth="220.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>