<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="HealthcareEveryday.controller.SeniorLogController">
    <children>
        <VBox spacing="16.0" AnchorPane.topAnchor="24.0" AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0" AnchorPane.bottomAnchor="24.0">
            <children>
                <Label fx:id="pageTitleLabel" styleClass="page-heading" />
                <Label fx:id="userLabel" styleClass="caption" />
                <Label text="How are you feeling today? Anything notable happened?" wrapText="true" styleClass="caption" />
                <TextArea fx:id="logArea" prefHeight="350.0" wrapText="true" VBox.vgrow="ALWAYS" />
                <Label fx:id="statusLabel" styleClass="status-success" />
                <HBox spacing="12.0">
                    <children>
                        <Button text="Page 1: Tasks" onAction="#handleBack" styleClass="ghost" prefWidth="160.0" />
                        <Button text="Submit today's record" onAction="#handleSubmit" prefWidth="220.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
