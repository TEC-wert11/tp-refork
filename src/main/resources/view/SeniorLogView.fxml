<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="SeniorLogController">
    <children>
        <VBox spacing="18.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <children>
                <Label fx:id="pageTitleLabel" style="-fx-font-size: 28; -fx-font-weight: bold;" />
                <Label fx:id="userLabel" style="-fx-font-size: 16;" />
                <Label text="How are you feeling today? Anything notable happened?" style="-fx-font-size: 16;" />
                <TextArea fx:id="logArea" prefHeight="350.0" wrapText="true" VBox.vgrow="ALWAYS" />
                <Label fx:id="statusLabel" style="-fx-text-fill: green;" />
                <HBox spacing="10.0">
                    <children>
                        <Button text="Page 1: Tasks" onAction="#handleBack" prefWidth="140.0" />
                        <Button text="Submit today's record" onAction="#handleSubmit" prefWidth="180.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
