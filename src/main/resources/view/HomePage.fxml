<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:controller="HomePageController" prefHeight="200.0" prefWidth="320.0" stylesheets="@/css/home.css" xmlns:fx="http://javafx.com/fxml">
    <VBox alignment="CENTER" spacing="15.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="30.0">
        <Label text="Select user" />
        <ComboBox fx:id="userCombo" prefWidth="200.0" />
        <Button onAction="#handleEnter" text="Enter" />
    </VBox>
</AnchorPane>
