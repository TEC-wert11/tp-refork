<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="SeniorTasksController">
    <children>
        <VBox spacing="18.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <children>
                <Label fx:id="pageTitleLabel" style="-fx-font-size: 28; -fx-font-weight: bold;" />
                <Label fx:id="userLabel" style="-fx-font-size: 16;" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 10;">
                            <children>
                                <Label text="Daily" style="-fx-font-size: 20;" />
                                <Label fx:id="dailyEmptyLabel" text="No daily tasks yet." visible="false" managed="false" />
                                <VBox fx:id="dailyContainer" spacing="10.0" />

                                <Label text="Weekly" style="-fx-font-size: 20;" />
                                <Label fx:id="weeklyEmptyLabel" text="No weekly tasks yet." visible="false" managed="false" />
                                <VBox fx:id="weeklyContainer" spacing="10.0" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <Label fx:id="statusLabel" style="-fx-text-fill: green;" />

                <HBox spacing="10.0">
                    <children>
                        <Button text="Back" onAction="#handleBack" prefWidth="120.0" />
                        <Button text="Page 2: Daily Log" onAction="#handleGoToLog" prefWidth="160.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
