<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="xmoke.controller.SeniorTasksController">
    <children>
        <VBox spacing="16.0" AnchorPane.topAnchor="24.0" AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0" AnchorPane.bottomAnchor="24.0">
            <children>
                <Label fx:id="pageTitleLabel" styleClass="page-heading" />
                <Label fx:id="userLabel" styleClass="caption" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="22.0" styleClass="panel-inset">
                            <children>
                                <Label text="Daily" styleClass="section-heading" />
                                <Label fx:id="dailyEmptyLabel" text="No daily tasks yet." visible="false" managed="false"
                                       styleClass="caption" />
                                <VBox fx:id="dailyContainer" spacing="12.0" />

                                <Label text="Weekly" styleClass="section-heading" />
                                <Label fx:id="weeklyEmptyLabel" text="No weekly tasks yet." visible="false" managed="false"
                                       styleClass="caption" />
                                <VBox fx:id="weeklyContainer" spacing="12.0" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

                <Label fx:id="statusLabel" styleClass="status-success" />

                <HBox spacing="12.0">
                    <children>
                        <Button text="Back" onAction="#handleBack" styleClass="ghost compact" prefWidth="120.0" />
                        <Button text="Page 2: Daily Log" onAction="#handleGoToLog" prefWidth="200.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
