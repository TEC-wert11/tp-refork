<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="HealthcareEveryday.controller.EditRoutineController">
    <children>
        <VBox spacing="18.0" AnchorPane.topAnchor="24.0" AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0" AnchorPane.bottomAnchor="24.0">
            <children>
                <Label fx:id="titleLabel" styleClass="page-heading" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" styleClass="panel-inset">
                            <children>
                                <Label text="Daily" styleClass="section-heading" />
                                <Button text="Add Daily Task" onAction="#handleAddDailyTask" styleClass="secondary" prefWidth="180.0" />
                                <VBox fx:id="dailyContainer" spacing="10.0" />

                                <Label text="Weekly" styleClass="section-heading" />
                                <Button text="Add Weekly Task" onAction="#handleAddWeeklyTask" styleClass="secondary" prefWidth="180.0" />
                                <VBox fx:id="weeklyContainer" spacing="10.0" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
                <HBox spacing="12.0">
                    <children>
                        <Button text="Back" onAction="#handleBack" styleClass="ghost" prefWidth="120.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
