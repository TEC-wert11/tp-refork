<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="EditRoutineController">
    <children>
        <VBox spacing="20.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
            <children>
                <Label fx:id="titleLabel" style="-fx-font-size: 24;" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 10;">
                            <children>
                                <Label text="Daily" style="-fx-font-size: 18;" />
                                <Button text="Add Daily Task" onAction="#handleAddDailyTask" prefWidth="150.0" />
                                <VBox fx:id="dailyContainer" spacing="8.0" />

                                <Label text="Weekly" style="-fx-font-size: 18;" />
                                <Button text="Add Weekly Task" onAction="#handleAddWeeklyTask" prefWidth="150.0" />
                                <VBox fx:id="weeklyContainer" spacing="8.0" />
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
                <HBox spacing="10.0">
                    <children>
                        <Button text="Back" onAction="#handleBack" prefWidth="120.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
