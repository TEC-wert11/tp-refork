<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="HealthcareEveryday.controller.DeleteUserController">
    <children>
        <VBox alignment="CENTER" spacing="18.0"
              AnchorPane.topAnchor="24.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="24.0">
            <children>
                <Label fx:id="titleLabel" styleClass="app-title" />

                <ScrollPane fitToWidth="true"
                            prefViewportHeight="320.0"
                            maxWidth="360.0"
                            hbarPolicy="NEVER"
                            styleClass="user-scroll">
                    <content>
                        <VBox fx:id="userContainer"
                              alignment="CENTER"
                              spacing="12.0"
                              styleClass="panel-inset" />
                    </content>
                </ScrollPane>

                <Button text="Back"
                        onAction="#handleBack"
                        styleClass="ghost"
                        prefWidth="300.0" />
            </children>
        </VBox>
    </children>
</AnchorPane>
